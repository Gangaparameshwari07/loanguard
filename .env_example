# ================================================
# LoanGuard Environment Variables
# ================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# ================================================


# Google Gemini API (Production / Hackathon Submission)
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1

# Arize Phoenix Cloud
PHOENIX_API_KEY=your_phoenix_api_key_here
PHOENIX_SPACE_NAME=your_space_name_here
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/your_space_name_here

# App Config
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO
